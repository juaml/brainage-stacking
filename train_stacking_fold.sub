##############################################
# Condor Submission File
# Brain Age Stacking Model (Fold-Based)
##############################################

# --- Executable ---
executable = /home/fkarateke/julearn_env/bin/python3
arguments = train_stacking.py $(features_dir) $(output_dir) --fold $(fold) --start_region $(start_region) --end_region $(end_region) --preset $(preset)

# --- Environment ---
getenv = True

# --- Working Directory ---
initialdir = /home/fkarateke/brainage-stacking

# --- File Transfers ---
should_transfer_files = NO

# --- Resources ---
request_cpus = 4
request_memory = 64GB
request_disk = 20GB

# --- Output Files ---
output = logs/condor_fold$(fold)_$(preset).out
error = logs/condor_fold$(fold)_$(preset).err
log = logs/condor_fold$(fold)_$(preset).log

# --- Notification (optional) ---
# notify_user = fkarateke@hhu.de
# notification = Complete

# --- Queue ---
queue
